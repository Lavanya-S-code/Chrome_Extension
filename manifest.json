{
  "manifest_version": 3,
  "name": "Tab Audio Transcriber (Deepgram)",
  "version": "1.2",
  "description": "Capture tab audio and transcribe in real time using Deepgram via local Python backend.",
  "permissions": [
    "storage",
    "scripting",
    "tabs",
    "activeTab",
    "tabCapture",
    "offscreen"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "main.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}